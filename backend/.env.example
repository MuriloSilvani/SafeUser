# Backend Environment Variables
# Copy this file to .env and fill in with your actual values

# Server Port
PORT=3001

# Environment
NODE_ENV=development

# Database Configuration
# For SQLite: sqlite:./database.sqlite
# For PostgreSQL: postgresql://user:password@localhost:5432/database
DATABASE_URL=sqlite:./database.sqlite

# JWT Secret Key (used for token generation and validation)
# Generate a secure random key for production
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# Encryption Key (must be exactly 32 characters for AES-256)
# Used to encrypt sensitive data like CPF and phone numbers
# Generate a 32-character random string for production
ENCRYPTION_KEY=abcdefghijklmnopqrstuvwx123456789012

# CORS Settings (optional)
# CORS_ORIGIN=http://localhost:3000
