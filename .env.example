# SafeUser Project - Environment Variables Example
# Copy this file to .env and fill in with your actual values

# Backend Configuration
BACKEND_PORT=3001
NODE_ENV=development

# Database Configuration
DATABASE_URL=sqlite:./database.sqlite

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# Encryption Configuration (must be exactly 32 characters for AES-256)
ENCRYPTION_KEY=abcdefghijklmnopqrstuvwx123456789012

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
